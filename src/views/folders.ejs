<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Folders</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <%- include("partials/header") %>
        <div class="container">
            <div class="card">
                <h2>Your Folders</h2>

                <!-- CREATE FOLDER -->
                <form method="POST" action="/folders">
                    <input name="name" placeholder="New folder name" required />
                    <button type="submit">Create Folder</button>
                </form>

                <!-- FOLDER LIST -->
                <ul>
                    <% folders.forEach(folder=> { %>
                        <li>
                            <a href="/folders/<%= folder.id %>">
                                📁 <%= folder.name %>
                            </a>

                            <div class="folder-actions">
                                <form method="POST" action="/share" class="share-form">
                                    <input type="hidden" name="folderId" value="<%= folder.id %>" />

                                    <input class="share-duration" name="duration" placeholder="Days" required />

                                    <button class="share-btn">Share</button>
                                </form>

                                <form method="POST" action="/folders/delete/<%= folder.id %>">
                                    <button class="delete-btn" type="submit">Delete</button>
                                </form>
                            </div>
                        </li>
                        <% }) %>
                </ul>
            </div>
        </div>
</body>

</html>
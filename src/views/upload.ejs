<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload File</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <%- include("partials/header") %>
        <div class="container">
            <div class="card">
                <h2>Upload File</h2>

                <!-- ERROR MESSAGE -->
                <% if (error) { %>
                    <p class="error-message">
                        <%= error %>
                    </p>
                    <% } %>

                        <form action="/upload" method="POST" enctype="multipart/form-data">


                            <% if (typeof currentFolder !=="undefined" ) { %>
                                <input type="hidden" name="folderId" value="<%= currentFolder.id %>" />
                                <% } %>

                                    <!-- Hidden real input -->
                                    <input type="file" id="fileInput" name="file" required hidden />

                                    <!-- Custom button -->
                                    <label for="fileInput" class="file-label">
                                        Choose File
                                    </label>

                                    <!-- File name display -->
                                    <span id="fileName">No file selected</span>

                                    <button type="submit">Upload</button>
                        </form>


                        <h3>Your Folders</h3>

                        <!-- FOLDER LIST -->
                        <ul>
                            <% folders.forEach(folder=> { %>
                                <li>
                                    <a href="/folders/<%= folder.id %>">
                                        📁 <%= folder.name %>
                                    </a>

                                    <div class="folder-actions">
                                        <form method="POST" action="/share" class="share-form">
                                            <input type="hidden" name="folderId" value="<%= folder.id %>" />

                                            <input class="share-duration" name="duration" placeholder="Days" required />

                                            <button class="share-btn">Share</button>
                                        </form>

                                        <form method="POST" action="/folders/delete/<%= folder.id %>">
                                            <button class="delete-btn" type="submit">Delete</button>
                                        </form>
                                    </div>
                                </li>
                                <% }) %>
                        </ul>
                        <h3>Create Folder</h3>

                        <form method="POST" action="/folders">
                            <input name="name" placeholder="Folder name" required />
                            <button type="submit">Create</button>
                        </form>

                        <h3>Your Files (No Folder)</h3>

                        <ul>
                            <% if (files.length> 0) { %>
                                <% files.forEach(file=> { %>
                                    <li>
                                        <a href="/files/<%= file.id %>">
                                            <%= file.filename %>
                                        </a>
                                    </li>
                                    <% }) %>
                                        <% } else { %>
                                            <p>No files uploaded yet</p>
                                            <% } %>
                        </ul>
            </div>
        </div>
        <script src="/script.js"></script>
</body>

</html>
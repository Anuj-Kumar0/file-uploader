<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title>Share Link</title>
</head>

<body>
    <h2>Share Link</h2>

    <p>Copy this link:</p>

    <input value="<%= link %>" readonly style="width:300px; cursor:text;" onclick="this.select();" />

    <a href="<%= link %>" target="_blank">Open</a>
</body>

</html>